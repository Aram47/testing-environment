generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

enum CompanyMemberStatus {
  ACTIVE
  REMOVED
}

enum ProjectRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum PrincipalType {
  USER
  SERVICE_ACCOUNT
  API_TOKEN
}

enum SubscriptionPlanName {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum EnvironmentConfigType {
  DOCKER_COMPOSE
  EXTERNAL_URL
}

enum OnboardingSessionStatus {
  IN_PROGRESS
  COMPLETED
}

enum TestRunStatus {
  CREATED
  QUEUED
  CLAIMED
  PREPARING_WORKSPACE
  VALIDATING_ENVIRONMENT
  PULLING_IMAGES
  STARTING_ENVIRONMENT
  WAITING_FOR_HEALTHCHECK
  EXECUTING_TESTS
  COLLECTING_ARTIFACTS
  CLEANING_UP
  PASSED
  TEST_FAILED
  INFRA_FAILED
  TIMED_OUT
  CANCEL_REQUESTED
  CANCELLED
}

enum TestRunFailureCategory {
  TEST_ASSERTION
  ENVIRONMENT_VALIDATION
  IMAGE_PULL
  CONTAINER_START
  HEALTHCHECK
  NETWORK
  TIMEOUT
  CANCELLED
  INTERNAL
}

enum TestResultStatus {
  PASSED
  FAILED
}

enum RunnerLogSource {
  SYSTEM
  DOCKER
  TEST
  ERROR
}

enum ArtifactType {
  SYSTEM_LOG
  DOCKER_LOG
  RESPONSE_BODY
  REPORT_JSON
  JUNIT_XML
}

enum ArtifactCompression {
  NONE
  GZIP
}

enum RevisionStatus {
  DRAFT
  PUBLISHED
}

enum TestSuiteSourceMode {
  VISUAL
  RAW_YAML
}

enum SecretRotationJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                            String                      @id @default(uuid())
  email                         String                      @unique
  passwordHash                  String
  firstName                     String
  lastName                      String
  role                          UserRole                    @default(OWNER)
  companyId                     String
  company                       Company                     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyMemberships            CompanyMember[]
  projectMemberships            ProjectMember[]
  environmentRevisionsCreated   EnvironmentConfigRevision[] @relation("EnvironmentRevisionCreatedBy")
  environmentRevisionsPublished EnvironmentConfigRevision[] @relation("EnvironmentRevisionPublishedBy")
  suiteRevisionsCreated         TestSuiteRevision[]         @relation("TestSuiteRevisionCreatedBy")
  suiteRevisionsPublished       TestSuiteRevision[]         @relation("TestSuiteRevisionPublishedBy")
  secretsCreated                Secret[]                    @relation("SecretCreatedBy")
  auditEvents                   AuditEvent[]                @relation("AuditEventActor")
  secretRotationJobs            SecretRotationJob[]         @relation("SecretRotationJobActor")
  onboardingSessions            OnboardingSession[]
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime                    @updatedAt

  @@index([companyId])
}

model Company {
  id                 String           @id @default(uuid())
  name               String
  subscriptionPlanId String
  subscriptionPlan   SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
  users              User[]
  members            CompanyMember[]
  invitations        Invitation[]
  serviceAccounts    ServiceAccount[]
  apiTokens          ApiToken[]
  projects           Project[]
  onboardingSessions OnboardingSession[]
  secretRotationJobs SecretRotationJob[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([subscriptionPlanId])
}

model CompanyMember {
  id        String              @id @default(uuid())
  companyId String
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      UserRole
  status    CompanyMemberStatus @default(ACTIVE)
  removedAt DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([companyId, userId])
  @@index([userId, status])
  @@index([companyId, status, role])
}

model ProjectMember {
  id        String      @id @default(uuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ProjectRole
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId, role])
}

model Invitation {
  id             String    @id @default(uuid())
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email          String
  role           UserRole
  invitedById    String?
  acceptedAt     DateTime?
  revokedAt      DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([companyId])
  @@index([email])
  @@index([acceptedAt, revokedAt])
}

model ServiceAccount {
  id          String     @id @default(uuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  apiTokens   ApiToken[]
  revokedAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([companyId])
  @@index([revokedAt])
}

model ApiToken {
  id               String          @id @default(uuid())
  companyId        String
  company          Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceAccountId String?
  serviceAccount   ServiceAccount? @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  name             String
  tokenHash        String          @unique
  scopes           String[]
  projectId        String?
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expiresAt        DateTime?
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([companyId])
  @@index([projectId])
  @@index([serviceAccountId])
  @@index([revokedAt])
}

model SubscriptionPlan {
  id                  String               @id @default(uuid())
  name                SubscriptionPlanName @unique
  maxProjects         Int
  maxRunsPerMonth     Int
  maxConcurrentRuns   Int
  maxRunnerMinutes    Int
  reportRetentionDays Int
  companies           Company[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Project {
  id                        String             @id @default(uuid())
  companyId                 String
  company                   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name                      String
  description               String?
  baseUrl                   String
  mainServiceName           String
  healthcheckPath           String
  healthcheckExpectedStatus Int                @default(200)
  healthcheckTimeoutSeconds Int                @default(60)
  environmentConfig         EnvironmentConfig?
  secrets                   Secret[]
  projectMembers            ProjectMember[]
  apiTokens                 ApiToken[]
  testSuites                TestSuite[]
  testRuns                  TestRun[]
  onboardingSessions        OnboardingSession[]
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([companyId])
}

model OnboardingSession {
  id                         String                  @id @default(uuid())
  companyId                  String
  company                    Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId                     String
  user                       User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId                  String?
  project                    Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status                     OnboardingSessionStatus @default(IN_PROGRESS)
  currentStep                String                  @default("project")
  draftData                  Json                    @default("{}")
  startedAt                  DateTime                @default(now())
  completedAt                DateTime?
  firstSuccessfulRunAt       DateTime?
  timeToFirstSuccessfulRunMs Int?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt

  @@index([companyId])
  @@index([userId, status])
  @@index([projectId])
}

model EnvironmentConfig {
  id        String                      @id @default(uuid())
  projectId String                      @unique
  project   Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      EnvironmentConfigType       @default(DOCKER_COMPOSE)
  revisions EnvironmentConfigRevision[]
  createdAt DateTime                    @default(now())
  updatedAt DateTime                    @updatedAt
}

model EnvironmentConfigRevision {
  id                  String            @id @default(uuid())
  environmentConfigId String
  environmentConfig   EnvironmentConfig @relation(fields: [environmentConfigId], references: [id], onDelete: Cascade)
  revisionNumber      Int
  status              RevisionStatus    @default(DRAFT)
  sourceMode          String
  visualConfig        Json?
  compiledComposeYaml String
  compiledRuntimeYaml String
  schemaVersion       Int               @default(1)
  createdById         String?
  createdBy           User?             @relation("EnvironmentRevisionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  publishedById       String?
  publishedBy         User?             @relation("EnvironmentRevisionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedAt         DateTime?
  testRuns            TestRun[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([environmentConfigId, revisionNumber])
  @@index([environmentConfigId, status, revisionNumber])
  @@index([createdById])
  @@index([publishedById])
}

model Secret {
  id                   String    @id @default(uuid())
  projectId            String
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key                  String
  encryptedValue       String
  encryptionKeyVersion String    @default("v1")
  lastUsedAt           DateTime?
  createdById          String?
  createdBy            User?     @relation("SecretCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  rotatedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([projectId, key])
  @@index([projectId])
  @@index([createdById])
  @@index([encryptionKeyVersion])
}

model AuditEvent {
  id               String        @id @default(uuid())
  type             String
  action           String
  companyId        String?
  projectId        String?
  actorType        PrincipalType @default(USER)
  actorUserId      String?
  actorUser        User?         @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  serviceAccountId String?
  apiTokenId       String?
  resourceType     String?
  resourceId       String?
  requestId        String?
  metadata         Json?
  createdAt        DateTime      @default(now())

  @@index([type])
  @@index([action])
  @@index([companyId])
  @@index([projectId])
  @@index([actorUserId])
  @@index([serviceAccountId])
  @@index([apiTokenId])
  @@index([resourceType, resourceId])
  @@index([requestId])
  @@index([resourceId])
  @@index([createdAt])
}

model SecretRotationJob {
  id                    String                  @id @default(uuid())
  status                SecretRotationJobStatus @default(PENDING)
  companyId             String
  company               Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromKeyVersion        String
  toKeyVersion          String
  totalSecrets          Int                     @default(0)
  processedSecrets      Int                     @default(0)
  lastProcessedSecretId String?
  errorMessage          String?
  actorUserId           String?
  actorUser             User?                   @relation("SecretRotationJobActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([status])
  @@index([companyId])
  @@index([fromKeyVersion, toKeyVersion])
  @@index([actorUserId])
  @@index([createdAt])
}

model TestSuite {
  id                String                 @id @default(uuid())
  projectId         String
  project           Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name              String
  revisions         TestSuiteRevision[]
  runSuiteRevisions TestRunSuiteRevision[]
  deletedAt         DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([projectId])
  @@index([projectId, deletedAt])
}

model TestSuiteRevision {
  id                String                 @id @default(uuid())
  testSuiteId       String
  testSuite         TestSuite              @relation(fields: [testSuiteId], references: [id], onDelete: Cascade)
  revisionNumber    Int
  status            RevisionStatus         @default(DRAFT)
  sourceMode        TestSuiteSourceMode
  visualFlow        Json?
  compiledYaml      String
  executionPlan     Json?
  schemaVersion     Int                    @default(1)
  createdById       String?
  createdBy         User?                  @relation("TestSuiteRevisionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  publishedById     String?
  publishedBy       User?                  @relation("TestSuiteRevisionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedAt       DateTime?
  runSuiteRevisions TestRunSuiteRevision[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@unique([testSuiteId, revisionNumber])
  @@index([testSuiteId, status, revisionNumber])
  @@index([createdById])
  @@index([publishedById])
}

model TestRun {
  id                          String                     @id @default(uuid())
  projectId                   String
  project                     Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentConfigRevisionId String?
  environmentConfigRevision   EnvironmentConfigRevision? @relation(fields: [environmentConfigRevisionId], references: [id], onDelete: SetNull)
  suiteRevisions              TestRunSuiteRevision[]
  runnerVersion               String                     @default("local")
  reportSchemaVersion         Int                        @default(1)
  status                      TestRunStatus              @default(CREATED)
  statusReason                String?
  failureCategory             TestRunFailureCategory?
  currentPhase                String?
  phaseTimestamps             Json?
  queueJobId                  String?
  queuedAt                    DateTime?
  enqueuedAt                  DateTime?
  claimedAt                   DateTime?
  cancellationRequestedAt     DateTime?
  cancelRequestedAt           DateTime?
  cancelRequestedBy           String?
  cancellationReason          String?
  runnerId                    String?
  leaseAcquiredAt             DateTime?
  leaseExpiresAt              DateTime?
  heartbeatAt                 DateTime?
  attempt                     Int                        @default(0)
  cleanupError                String?
  startedAt                   DateTime?
  finishedAt                  DateTime?
  totalTests                  Int                        @default(0)
  passedTests                 Int                        @default(0)
  failedTests                 Int                        @default(0)
  durationMs                  Int?
  errorMessage                String?
  results                     TestResult[]
  logs                        RunnerLog[]
  artifacts                   Artifact[]
  logChunks                   RunnerLogChunk[]
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt

  @@index([projectId])
  @@index([environmentConfigRevisionId])
  @@index([status])
  @@index([queueJobId])
  @@index([runnerId])
  @@index([leaseExpiresAt])
  @@index([createdAt])
}

model TestRunSuiteRevision {
  id                  String            @id @default(uuid())
  testRunId           String
  testRun             TestRun           @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testSuiteId         String?
  testSuite           TestSuite?        @relation(fields: [testSuiteId], references: [id], onDelete: SetNull)
  testSuiteRevisionId String
  testSuiteRevision   TestSuiteRevision @relation(fields: [testSuiteRevisionId], references: [id], onDelete: Restrict)
  position            Int
  suiteName           String
  createdAt           DateTime          @default(now())

  @@unique([testRunId, testSuiteRevisionId])
  @@unique([testRunId, position])
  @@index([testSuiteId])
  @@index([testSuiteRevisionId])
}

model TestResult {
  id             String           @id @default(uuid())
  testRunId      String
  testRun        TestRun          @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  stepId         String?
  stepType       String           @default("apiRequest")
  suiteName      String
  testName       String
  status         TestResultStatus
  method         String
  path           String
  expectedStatus Int
  actualStatus   Int?
  attempts       Int              @default(1)
  durationMs     Int
  requestBody    Json?
  responseBody   Json?
  responsePreview Json?
  responsePreviewTruncated Boolean @default(false)
  responseArtifactId String?
  responseArtifact Artifact? @relation("TestResultResponseArtifact", fields: [responseArtifactId], references: [id], onDelete: SetNull)
  errorMessage   String?
  createdAt      DateTime         @default(now())

  @@index([testRunId])
  @@index([stepId])
  @@index([responseArtifactId])
}

model RunnerLog {
  id        String          @id @default(uuid())
  testRunId String
  testRun   TestRun         @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  source    RunnerLogSource
  message   String
  createdAt DateTime        @default(now())

  @@index([testRunId])
}

model Artifact {
  id             String              @id @default(uuid())
  testRunId      String
  testRun        TestRun             @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  responseResults TestResult[]       @relation("TestResultResponseArtifact")
  logChunks      RunnerLogChunk[]
  stepId         String?
  type           ArtifactType
  objectKey      String              @unique
  mimeType       String
  byteSize       Int
  checksum       String
  compression    ArtifactCompression @default(NONE)
  retentionUntil DateTime
  createdAt      DateTime            @default(now())

  @@index([testRunId])
  @@index([stepId])
  @@index([type])
  @@index([retentionUntil])
}

model RunnerLogChunk {
  id        String          @id @default(uuid())
  testRunId String
  testRun   TestRun         @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  artifactId String?
  artifact Artifact?        @relation(fields: [artifactId], references: [id], onDelete: SetNull)
  source    RunnerLogSource
  sequence  Int
  preview   String
  byteSize  Int
  truncated Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@unique([testRunId, source, sequence])
  @@index([testRunId])
  @@index([artifactId])
}
