NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/backend_test_runner?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
SECRET_ENCRYPTION_KEY=replace-with-32-byte-base64-key
RUNNER_WORKSPACE_ROOT=/tmp/backend-test-runner
RUNNER_REQUEST_TIMEOUT_MS=30000
RUNNER_DEFAULT_TIMEOUT_MINUTES=10
TEST_RUN_RUNNER_ID=
TEST_RUN_LEASE_DURATION_MS=60000
TEST_RUN_HEARTBEAT_INTERVAL_MS=15000
TEST_RUN_CANCELLATION_POLL_INTERVAL_MS=1000
TEST_RUN_JANITOR_INTERVAL_MS=30000
